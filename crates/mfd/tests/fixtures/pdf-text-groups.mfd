                </entry>
              </entry>
            </root>
          </data>
        </component>
        <component name="items" library="text" uid="3" kind="16">
          <properties XSLTDefaultOutput="1"/>
          <data>
            <root>
              <header><namespaces><namespace/></namespaces></header>
              <entry name="FileInstance"><entry name="document">
                <entry name="Rows" inpkey="20">
                  <entry name="Code" inpkey="21"/>
                  <entry name="Name" inpkey="22"/>
                </entry>
              </entry></entry>
            </root>
            <text type="csv" outputinstance="items.csv">
              <settings separator="," firstrownames="true">
                <names root="Items" block="Rows">
                  <field0 name="Code" type="string"/>
                  <field1 name="Name" type="string"/>
