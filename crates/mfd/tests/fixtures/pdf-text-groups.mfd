<mapping version="42">
  <resources/>
  <component name="warehouse-map" uid="1">
    <properties SelectedLanguage="builtin"/>
    <structure>
      <children>
        <component name="warehouse-pdf" library="pdf" uid="2" kind="34">
          <data>
            <root>
              <header><namespaces><namespace/></namespaces></header>
              <entry name="FileInstance">
                <file role="inputinstance" name="warehouse.pdf"/>
                <entry name="document" type="doc-pdf">
                  <document schemafile="warehouse.pxt" root="WarehouseReport"/>
                  <entry name="WarehouseReport">
                    <entry name="Item" outkey="1">
                      <entry name="Code" outkey="2"/>
                      <entry name="Name" outkey="3"/>
                      <entry name="Note" outkey="4"/>
                      <entry name="Location" outkey="5">
                        <entry name="Label" outkey="6"/>
                        <entry name="Stock" outkey="7">
                          <entry name="Variant" outkey="8"/>
                          <entry name="Quantity" outkey="9"/>
                        </entry>
                      </entry>
                    </entry>
